# Tavily key enables the Web Research agent. Leave blank to skip external research.
TAVILY_API_KEY=

# Override auto-detected models if you want to force specific sizes.
# OCR_MODEL=llava:7b
# ANALYST_MODEL=deepseek-r1:7b
# EMBED_MODEL=nomic-embed-text

# Where the runtime model config file is written.
# INSUREIQ_MODEL_CONFIG=/tmp/model_config.env
